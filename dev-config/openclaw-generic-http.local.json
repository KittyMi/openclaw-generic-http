{
  "channels": {
    "generic-http": {
      "enabled": true,
      "defaultAccount": "default",
      "accounts": {
        "default": {
          "displayName": "Generic HTTP Local",
          "baseUrl": "http://127.0.0.1:18082",
          "apiKey": "local-dev-api-key",
